# App
APP_ENV=development
APP_DOMAIN=example.noveris.ai
ADMIN_DOMAIN=example-admin.noveris.ai
ENABLE_API_DOCS=true

# Database
DB_URL=postgresql+asyncpg://navima:navima@localhost:5432/navima
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=
SESSION_TIMEOUT_SECONDS=43200
SESSION_COOKIE_NAME=session_id
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_REDIS_PREFIX=navima:session:
CSRF_SECRET=
RATE_LIMIT_REDIS_PREFIX=navima:rate:

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Forward proxy settings
FORWARD_CONNECT_TIMEOUT=5.0
FORWARD_READ_TIMEOUT=60.0
FORWARD_MAX_REQUEST_SIZE=104857600

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
SMTP_FROM=noreply@noveris.ai

# License
LICENSE_SERVER_URL=

# Branding fallback
DEFAULT_BRAND_NAME=Navima
DEFAULT_LOGO_URL=

# HuggingFace
HF_ENDPOINT=https://huggingface.co
HF_API_TOKEN=

# Object Storage (MinIO/S3)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=
S3_USE_SSL=true
